# Backend Environment Vairables (.env)
PORT=4000
DATABASE_URL="postgresql://user:password@localhost:5432/digital_executor"

# Redis
REDIS_URL="redis://localhost:6379"

# AWS Config (KMS & S3)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your_aws_access_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret_key"
VAULT_BUCKET_NAME="digital-executor-vault-storage"
KMS_KEY_ID="your_kms_key_id"

# Notification Providers
TWILIO_ACCOUNT_SID="your_twilio_sid"
TWILIO_AUTH_TOKEN="your_twilio_token"
TWILIO_PHONE_NUMBER="+1234567890"

SENDGRID_API_KEY="your_sendgrid_key"
SENDGRID_FROM_EMAIL="vault@familyinstructionmanual.com"
